# =============================================
# PropNest AI — Environment Variables
# Copy ke .env.local dan isi nilai yang sesuai
# =============================================

# Supabase — https://supabase.com/dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Groq AI — https://console.groq.com
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxx

# Resend Email — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# App Config
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=PropNest AI

# WhatsApp (Fonnte) — https://fonnte.com
FONNTE_TOKEN=your-fonnte-token

# Meta Business API (Phase 2)
# META_APP_ID=
# META_APP_SECRET=
# META_ACCESS_TOKEN=

# TikTok API (Phase 2)
# TIKTOK_CLIENT_KEY=
# TIKTOK_CLIENT_SECRET=
